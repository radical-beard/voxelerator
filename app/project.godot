; Engine configuration file.
config_version=5

[application]

config/name="Voxelerator"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6", "C#")

[display]

window/size/viewport_width=1440
window/size/viewport_height=900
window/size/window_width_override=1440
window/size/window_height_override=900

[dotnet]

project/assembly_name="Voxelerator.App"

[rendering]

renderer/rendering_method="forward_plus"
environment/defaults/default_clear_color=Color(0.055, 0.05, 0.07, 1)
anti_aliasing/quality/msaa_3d=2
