<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================================
     DO NOT ADD A LOCAL / FILE-SYSTEM PACKAGE SOURCE HERE. EVER.

     The Evaluate framework (RadicalBeard.Evaluate) is consumed ONLY from
     nuget.org — same law as neo-terrestria and eye-of-the-undertaker. A local
     feed exists on exactly one machine and makes `dotnet restore` break or
     silently diverge everywhere else (including CI).

     To ship a framework change: push a `v<version>` tag in the
     radical-beard/evaluate repo (the publish-nuget action packs + pushes),
     then bump the <PackageReference> in app/Voxelerator.App.csproj.

     <clear /> is intentional: it drops any inherited user/machine NuGet
     sources so restore is deterministic — nuget.org and nothing else.
     ============================================================================ -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
